# ═══════════════════════════════════════════════════════════════════════════════
# Crypto IA Auditor - Enterprise API Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ─── Security (CHANGE IN PRODUCTION!) ────────────────────────────────────────
SECRET_KEY=change-me-run-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./crypto_ia.db

# ─── Redis (optional - for distributed rate limiting) ────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ─── OpenAI (REQUIRED) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
LLM_MODEL=gpt-4-turbo
LLM_TEMPERATURE=0.3

# ─── Blockchain APIs (optional - uses sample data without keys) ──────────────
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# ─── News API (optional - uses simulated news without key) ───────────────────
NEWSAPI_KEY=

# ─── Stripe Payments (optional - simulated without keys) ────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
